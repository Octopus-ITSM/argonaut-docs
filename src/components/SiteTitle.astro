---
// Header brand: the Octopus "o-mark" (green square, dark O) + site title,
// linked to the localized home. Faithful to the portal mockups' header.
const base = import.meta.env.BASE_URL;
const locale = Astro.locals.starlight?.locale;
const href = locale ? `${base}${locale}/` : base;
const title = Astro.locals.starlight?.siteTitle ?? 'Argonaut Docs';
---

<a href={href} class="site-brand">
  <span class="o-mark" aria-hidden="true">O</span>
  <span class="site-brand-text">{title}</span>
</a>

<style>
  .site-brand {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    text-decoration: none;
  }
  .o-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 0.5rem;
    background: var(--octopus-green);
    color: var(--octopus-dark);
    font-weight: 800;
    font-size: 0.8125rem;
    line-height: 1;
  }
  .site-brand-text {
    font-weight: 700;
    font-size: 0.9375rem;
    letter-spacing: -0.01em;
    color: var(--ink);
  }
</style>
