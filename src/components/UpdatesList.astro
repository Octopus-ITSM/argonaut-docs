---
import { getSortedUpdates, UPDATES_PER_PAGE } from '../lib/updates';

interface Props {
  // 1-based page number; page 1 is the docs index, 2+ are /2/, /3/, … routes.
  page?: number;
}
const page = Astro.props.page ?? 1;

// Resolve the current language. Within Starlight, `locals.starlight.lang`
// is the most reliable source; fall back to Astro's locale, then English.
const lang = (Astro.locals.starlight?.lang ?? Astro.currentLocale ?? 'en').split('-')[0];
const locale = (lang === 'fr' ? 'fr' : 'en') as 'en' | 'fr';

// Each file holds both languages; the body is split by <!-- en --> / <!-- fr -->
// markers (comments survive the markdown pipeline into the rendered HTML).
// Anything before the first marker is shared by both languages — same
// convention as the bilingual docs sources (src/content-src/docs/).
function pickSection(html: string, target: 'en' | 'fr'): string {
  const tokens = html.split(/<!--\s*(en|fr)\s*-->/gi);
  const shared = tokens[0] ?? '';
  const sections: Record<string, string> = { en: '', fr: '' };
  for (let i = 1; i < tokens.length; i += 2) {
    sections[tokens[i].toLowerCase()] += tokens[i + 1] ?? '';
  }
  const own = sections[target].trim() ? sections[target] : sections.en;
  return (shared + own).trim();
}

const all = await getSortedUpdates();
const totalPages = Math.max(1, Math.ceil(all.length / UPDATES_PER_PAGE));
const raw = all.slice((page - 1) * UPDATES_PER_PAGE, page * UPDATES_PER_PAGE);

// Newest-first list: the previous page holds newer entries, the next older.
const base = import.meta.env.BASE_URL;
const pageUrl = (n: number) =>
  `${base}${locale === 'fr' ? 'fr/' : ''}${n > 1 ? `${n}/` : ''}`;

const entries = raw.map((entry) => ({
  entry,
  title: entry.data.title[locale],
  description: entry.data.description[locale],
  html: pickSection(entry.rendered?.html ?? '', locale),
}));

// Format in UTC: bare YAML dates parse as UTC midnight, so formatting in the
// local zone (e.g. UTC-4) would shift the displayed day back by one.
const dateFmt = new Intl.DateTimeFormat(locale, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'UTC',
});

const strings = {
  en: { empty: 'No updates yet.', tag: 'Update', details: 'Details', newer: 'Newer', older: 'Older', pagination: 'Pagination' },
  fr: { empty: 'Aucune nouveauté pour le moment.', tag: 'Nouveauté', details: 'Détails', newer: 'Plus récentes', older: 'Plus anciennes', pagination: 'Pagination' },
} as const;
const t = strings[locale];
---

{entries.length === 0 && <p class="updates-empty">{t.empty}</p>}

<div class="updates">
  {entries.map(({ entry, title, description, html }) => (
    <details class="update">
      <summary class="update-summary">
       <span class="update-row">
        {/* Colored icon tile — megaphone, per the Annonces cards. */}
        <span class="update-icon" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="m3 11 18-5v12L3 13v-2z" /><path d="M11.6 16.8a3 3 0 1 1-5.8-1.6" />
          </svg>
        </span>
        <span class="update-main">
          <span class="update-head">
            <span class="pill pill-green">{t.tag}</span>
            <time class="update-date" datetime={entry.data.date.toISOString()}>{dateFmt.format(entry.data.date)}</time>
          </span>
          <span class="update-title">{title}</span>
          <span class="update-desc">{description}</span>
        </span>
        <svg class="update-chevron" aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="m9 6 6 6-6 6" /></svg>
       </span>
      </summary>
      <div class="update-body">
        <div class="update-details">
          <Fragment set:html={html} />
        </div>
      </div>
    </details>
  ))}
</div>

{totalPages > 1 && (
  <nav class="pager" aria-label={t.pagination}>
    {page > 1 ? (
      <a class="pager-link" href={pageUrl(page - 1)} rel="prev">← {t.newer}</a>
    ) : (
      <span class="pager-link is-disabled">← {t.newer}</span>
    )}
    <span class="pager-status">{page} / {totalPages}</span>
    {page < totalPages ? (
      <a class="pager-link" href={pageUrl(page + 1)} rel="next">{t.older} →</a>
    ) : (
      <span class="pager-link is-disabled">{t.older} →</span>
    )}
  </nav>
)}

<style>
  .updates {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }
  .updates-empty {
    color: var(--ink-3);
  }

  /* Card: white surface on the off-white page, hairline border, 16px radius. */
  .update {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 16px;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .update:hover {
    border-color: var(--line-strong);
  }

  /* Block summary (marker removal is reliable here); flex lives on the row. */
  .update-summary {
    display: block;
    padding: 1rem 1.125rem;
    cursor: pointer;
    list-style: none;
  }
  .update-summary::-webkit-details-marker {
    display: none;
  }
  .update-row {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
  }

  /* Colored icon tile. */
  .update-icon {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 0.75rem;
    background: var(--octopus-green-softer);
    color: var(--octopus-green-deeper);
  }

  .update-main {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .update-head {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .update-date {
    font-size: 0.75rem;
    color: var(--ink-3);
  }
  .update-title {
    font-size: 0.9375rem;
    font-weight: 600;
    line-height: 1.35;
    color: var(--ink);
  }
  .update-desc {
    font-size: 0.8125rem;
    line-height: 1.45;
    color: var(--ink-2);
  }

  /* Chevron rotates when the card is expanded. */
  .update-chevron {
    flex-shrink: 0;
    margin-top: 0.5rem;
    color: var(--ink-4);
    transition: transform 0.15s;
  }
  .update[open] .update-chevron {
    transform: rotate(90deg);
  }

  /* Collapsible body, aligned under the title column. */
  .update-body {
    padding: 0 1.125rem 1.125rem;
    margin-left: 3.125rem; /* icon (2.25rem) + gap (0.875rem) */
  }
  .update-details {
    padding-top: 0.875rem;
    border-top: 1px solid var(--line);
    font-size: 0.875rem;
    color: var(--ink-2);
  }
  .update-details :global(ul) {
    margin: 0;
    padding-left: 1.1rem;
  }
  .update-details :global(li) {
    margin: 0.25rem 0;
  }
  .update-details :global(li)::marker {
    color: var(--octopus-green-deeper);
  }

  /* Pagination: bordered chips, same vocabulary as the update cards. */
  .pager {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-top: 1.25rem;
  }
  .pager-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 7px 12px;
    border-radius: 9px;
    background: #fff;
    border: 1px solid var(--line);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--ink-2);
    text-decoration: none;
  }
  a.pager-link:hover {
    border-color: var(--line-strong);
  }
  .pager-link.is-disabled {
    color: var(--ink-4);
    background: transparent;
  }
  .pager-status {
    font-size: 0.8125rem;
    color: var(--ink-3);
  }

  @media (max-width: 30rem) {
    .update-body {
      margin-left: 0;
    }
  }
</style>
